@model List<Movie>

<div class="container py-5">

    <a href="/Admin/Create" class="btn btn-success mb-3">+ Add Movie</a>

    <table class="table table-dark text-center">
        <thead>
            <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Category</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var m in Model)
            {
                <tr>
                    <td>
                        <img src="/images/movies/@(m.MainImg ?? "default.jpg")" width="80" />
                    </td>

                    <td>@m.Name</td>

                    <td>@m.Category?.CategoryName</td>

                    <td>
                        <a href="/Admin/Edit?id=@m.Id" class="btn btn-warning">Edit</a>
                        <a href="/Admin/Delete?id=@m.Id" class="btn btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>