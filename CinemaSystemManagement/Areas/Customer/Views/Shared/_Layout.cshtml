<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Cinema System</title>

    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/admin-movie.css" rel="stylesheet" />
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm px-4">
        <a class="navbar-brand fw-bold" asp-area="Customer" asp-controller="Home" asp-action="Movie">
            🎬 Cinema
        </a>

        <div class="ms-auto d-flex gap-2">

            <a asp-area="Customer"
                   asp-controller="Home"
                   asp-action="Movie"
                   class="btn btn-outline-primary">
                Movies
            </a>

            <a asp-area="Identity"
                   asp-controller="Profile"
                   asp-action="Index"
                   class="btn btn-outline-primary">
                My Profile
            </a>

            <a asp-area="Customer"
                   asp-controller="Home"
                   asp-action="Categories"
                   class="btn btn-outline-secondary">
                Categories
            </a>

            <a asp-area="Customer"
                   asp-controller="Home"
                   asp-action="Transactions"
                   class="btn btn-outline-success">
                My Movies
            </a>

            @if (User.Identity.IsAuthenticated)
            {
                <a asp-area="Identity"
                       asp-controller="Account"
                       asp-action="Logout"
                       class="btn btn-danger">
                    Logout
                </a>
            }
            else
            {
                <a asp-area="Identity"
                       asp-controller="Account"
                       asp-action="Login"
                       class="btn btn-warning">
                    Login
                </a>
            }

        </div>
    </nav>

    <div class="container-fluid">
        @RenderBody()
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>