@model List<CinemaSystemManagement.Models.Transaction>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

<link href="~/css/admin-movie.css" rel="stylesheet" />


<div class="container py-5">

    <div class="page-header">
        <p class="page-subtitle">Your collection</p>
        <h2 class="page-title">My Movies</h2>
        <div class="page-divider"></div>
    </div>

    @if (Model.Any())
    {
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-value">@Model.Count</div>
                <div class="stat-label">Films</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">$@Model.Sum(t => t.Price).ToString("0.##")</div>
                <div class="stat-label">Total spent</div>
            </div>
        </div>

        <div class="movies-grid">
            @foreach (var t in Model)
            {
                <div class="movie-card">
                    <div class="movie-poster">
                        <img src="/images/movies/@t.MovieImg"
                             onerror="this.src='/img/default.jpg'"
                             alt="@t.MovieName" />
                        <span class="price-badge">$@t.Price</span>
                    </div>
                    <div class="movie-info">
                        <p class="movie-name" title="@t.MovieName">@t.MovieName</p>
                        <p class="movie-date">@t.Date.ToString("dd MMM yyyy")</p>
                        <div class="card-footer">
                            <span class="movie-price">$@t.Price</span>
                            <a asp-area="Customer"
                            asp-controller="Home"
                            asp-action="DeleteTransaction"
                            asp-route-id="@t.Id"
                            class="btn-delete">Delete</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <p>No movies yet. Start adding some!</p>
        </div>
    }

</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
