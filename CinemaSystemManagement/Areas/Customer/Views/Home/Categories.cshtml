@model List<CinemaSystemManagement.Areas.Customer.Models.Category>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

<style>
    body {
        background: #0f172a;
        color: white;
        font-family: 'DM Sans', sans-serif;
    }

    h2 {
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        color: #f1f5f9;
    }

    .category-container {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 25px;
    }

    .category-card {
        background: rgba(255,255,255,0.05);
        border-radius: 20px;
        overflow: hidden;
        transition: 0.4s ease;
        backdrop-filter: blur(10px);
        cursor: pointer;
        position: relative;
    }

        .category-card:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 30px rgba(0, 212, 255, 0.4);
        }

    .img-wrapper {
        width: 100%;
        height: 220px;
        overflow: hidden;
    }

    .category-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .category-card:hover .category-img {
        transform: scale(1.1);
    }

    .overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.85), transparent);
        opacity: 0.8;
        transition: 0.3s;
    }

    .category-card:hover .overlay {
        opacity: 1;
    }

    .category-name {
        position: absolute;
        bottom: 15px;
        left: 0;
        right: 0;
        font-size: 22px;
        font-weight: bold;
        color: white;
        z-index: 2;
        text-align: center;
        padding: 0 10px;
    }

    a {
        text-decoration: none;
    }
</style>

<div class="container py-5">

    <h2 class="text-center mb-5">🎭 Categories</h2>

    <div class="category-container">

        @foreach (var cat in Model)
        {
            var img = cat.Movies.FirstOrDefault(m => m.MainImg != null)?.MainImg ?? "default.jpg";

            <a asp-area="Customer"
                   asp-controller="Home"
                   asp-action="CategoryMovies"
                   asp-route-id="@cat.Id">

                <div class="category-card">

                    <div class="img-wrapper">
                        <img src="/images/movies/@img"
                             class="category-img"
                             onerror="this.src='/images/default.jpg'" />
                    </div>

                    <div class="overlay"></div>

                    <div class="category-name">
                        @cat.CategoryName
                    </div>

                </div>

            </a>
        }

    </div>

</div>