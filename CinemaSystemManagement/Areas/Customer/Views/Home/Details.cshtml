@model CinemaSystemManagement.Models.Products

<div class="container py-5">

    <div class="row mb-5">

        <div class="col-md-4">
            <img src="/images/movies/@Model.MainImg" class="w-100 rounded" />
        </div>

        <div class="col-md-8">
            <h1>@Model.Name</h1>

            <p>@Model.Description</p>

            <p><b>Price:</b> @Model.Price</p>
            <p><b>Category:</b> @Model.Category?.CategoryName</p>

            <a href="/Home/AddTransaction?id=@Model.Id" class="btn btn-success">
                Buy Now
            </a>
        </div>

    </div>

    <!-- Actors -->
    <h3>🎭 Cast</h3>
    <div class="row mb-5">
        @foreach (var a in Model.MovieActors)
        {
            <div class="col-md-2 text-center">
                <img src="/images/actors/@a.Actor.Img"
                     class="w-100 rounded-circle mb-2"
                     style="height:120px; object-fit:cover;" />
                <p>@a.Actor.Name</p>
            </div>
        }
    </div>

    <!-- 🔥 Sub Images -->
    <h3>📸 More Images</h3>

    <div class="row">
        @if (Model.SubImages != null && Model.SubImages.Any())
        {
            foreach (var img in Model.SubImages)
            {
                <div class="col-md-3 mb-3">
                    <img src="/images/movies/sub/@img.ImageUrl"
                         class="img-fluid rounded" />
                </div>
            }
        }
        else
        {
            <p>No extra images</p>
        }
    </div>

</div>