@model CinemaSystemManagement.Models.ShowTime

<div class="container py-5">

    <h2>@Model.Movie.Name</h2>
    <p>@Model.StartTime.ToString("dd MMM hh:mm tt")</p>

    <h4 class="mt-4">Select Your Seat</h4>

    <div class="seat-grid">

        @foreach (var seat in Model.Seats)
        {
            <button class="seat @(seat.IsBooked ? "booked" : "")"
                    data-id="@seat.Id">

                @seat.Row-@seat.Number
            </button>
        }

    </div>

    <form method="post"
          asp-action="Checkout"
          asp-controller="Booking">

        <input type="hidden" name="showId" value="@Model.Id" />
        <input type="hidden" id="seatId" name="seatId" />

        <button class="btn btn-success mt-3">
            Continue to Payment
        </button>

    </form>

</div>

<script>
    document.querySelectorAll(".seat").forEach(btn => {

        btn.addEventListener("click", function () {

            if (this.classList.contains("booked")) return;

            document.querySelectorAll(".seat").forEach(b => b.classList.remove("selected"));

            this.classList.add("selected");

            document.getElementById("seatId").value = this.dataset.id;
        });
    });
</script>

<style>
    .seat {
        width: 50px;
        height: 50px;
        margin: 5px;
        background: #ccc;
        border: none;
    }

        .seat.selected {
            background: red;
        }

        .seat.booked {
            background: black;
            color: white;
        }

    .seat-grid {
        display: flex;
        flex-wrap: wrap;
        max-width: 300px;
    }
</style>