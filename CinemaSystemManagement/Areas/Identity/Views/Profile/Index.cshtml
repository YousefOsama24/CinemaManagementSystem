@model CinemaSystemManagement.ViewModels.ApplicationUserVM

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-start px-4">
        <a asp-area="Customer"
               asp-controller="Home"
               asp-action="Movie"
               class="btn-cinema">
             Cinema Movies
        </a>
    </div>
</div>

<div class="container mt-4" style="max-width:600px;">

    <h2 class="text-center mb-4"> My Profile</h2>

    <form asp-action="Update" method="post" enctype="multipart/form-data">

        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="text-center mb-3">

            @if (!string.IsNullOrEmpty(Model.ProfileImage))
            {
                <img src="/images/profile/@Model.ProfileImage"
                     class="rounded-circle"
                     width="120"
                     height="120"
                     style="object-fit:cover;" />
            }
            else
            {
                <img src="/images/profile/default.png"
                     class="rounded-circle"
                     width="120"
                     height="120" />
            }

        </div>

        <div class="mb-3">
            <label>Profile Picture</label>
            <input asp-for="Image" type="file" class="form-control" />
        </div>

        <div class="mb-3">
            <label>First Name</label>
            <input asp-for="FirstName" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Last Name</label>
            <input asp-for="LastName" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Email</label>
            <input asp-for="Email" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Phone</label>
            <input asp-for="PhoneNumber" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Address</label>
            <input asp-for="Address" class="form-control" />
        </div>

        <button class="btn btn-primary w-100">
            Update Profile
        </button>

    </form>

    <div class="text-center mt-3">
        <a asp-action="ChangePassword" class="btn btn-outline-dark">
            Change Password 
        </a>
    </div>

    <div class="text-center mt-2">
        <a asp-action="Logout" class="btn btn-danger">
            Logout
        </a>
    </div>

</div>

@if (TempData["success-notification"] != null)
{
    <div class="alert alert-success text-center mt-3">
        @TempData["success-notification"]
    </div>
}

@if (TempData["error-notification"] != null)
{
    <div class="alert alert-danger text-center mt-3">
        @TempData["error-notification"]
    </div>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    .btn-cinema {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: linear-gradient(135deg, #0ea5e9, #2563eb);
        color: white;
        padding: 12px 28px;
        border-radius: 14px;
        font-weight: 600;
        font-size: 15px;
        text-decoration: none;
        transition: all 0.3s ease;
    }

        .btn-cinema:hover {
            transform: translateY(-3px) scale(1.03);
            box-shadow: 0 8px 20px rgba(0,0,0,0.25);
            color: white;
        }

        .btn-cinema:active {
            transform: scale(0.97);
        }

    .btn-cinema {
        position: relative;
        overflow: hidden;
    }

        .btn-cinema::after {
            content: "";
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: rgba(255,255,255,0.2);
            transition: 0.4s;
        }

        .btn-cinema:hover::after {
            left: 100%;
        }
</style>
