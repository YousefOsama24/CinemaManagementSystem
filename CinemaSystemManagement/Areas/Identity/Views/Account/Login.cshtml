@model CinemaSystemManagement.ViewModels.LoginVM

<div class="container mt-5" style="max-width:500px;">
    <h2 class="text-center mb-4">Login</h2>

    <form method="post">

        <div class="mb-3">
            <input asp-for="UserNameOrEmail" class="form-control" placeholder="Email or Username" />
            <span asp-validation-for="UserNameOrEmail" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <input asp-for="Password" type="password" class="form-control" placeholder="Password" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <input asp-for="RememberMe" type="checkbox" /> Remember Me
        </div>

        <button class="btn btn-primary w-100">Login</button>
    </form>

    <div class="mt-3 text-center">
        <a asp-action="Register">Create Account</a> |
        <a asp-action="ForgetPassword">Forgot Password?</a>
    </div>
</div>