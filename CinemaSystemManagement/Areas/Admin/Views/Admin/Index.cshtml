
<link href="~/css/admin-movie.css" rel="stylesheet" />


<div class="admin-movie-page">

    <div class="admin-header">
        <h2>🎬 Admin Dashboard</h2>
        
        <div class="actions">

            <a asp-area="Admin"
                   asp-controller="Admin"
                   asp-action="Create"
                   class="btn-add">
                + Add Movie
            </a>

            <a asp-area="Customer"
                   asp-controller="Home"
                   asp-action="Index"
                   class="btn-dashboard">
                Dashboard
            </a>

        </div>
    </div>

    <div class="table-container">

        <table class="movie-table">

            <thead>
                <tr>
                    <th style="width:100px;">Image</th>
                    <th>Name</th>
                    <th style="width:150px;">Category</th>
                    <th style="width:120px;">Price</th>
                    <th style="width:120px;">Status</th>
                    <th style="width:160px;">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var m in Model)
                {
                    <tr>
                        <td class="img-cell">
                            <img src="/images/movies/@(m.MainImg ?? "default.jpg")" class="movie-img" />
                        </td>

                        <td>@m.Name</td>
                        <td>@m.Category?.CategoryName</td>
                        <td>$@m.Price</td>

                        <td>
                            <span class="status available">@m.Status</span>
                        </td>

                        <td>
                            <a asp-action="Edit" asp-route-id="@m.Id" class="btn-edit">Edit</a>
                            <a asp-action="Delete" asp-route-id="@m.Id" class="btn-delete">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>
</div>