@model List<CinemaSystemManagement.Models.Products>


<link href="~/css/admin-movie.css" rel="stylesheet" />

 

<div class="container py-5">

    <a asp-area="Admin" asp-controller="Home" asp-action="Create" class="btn btn-success mb-3">
        + Add Movie
    </a>

    <table class="table table-hover text-center">
        <thead>
            <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Category</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var m in Model)
            {
                <tr>
                    <td>
                        <img src="/images/movies/@(m.MainImg ?? "default.jpg")" width="80" />
                    </td>

                    <td>@m.Name</td>

                    <td>@m.Category?.CategoryName</td>

                    <td>
                        <a asp-area="Admin" asp-controller="Home" asp-action="Edit" asp-route-id="@m.Id" class="btn btn-warning">
                            Edit
                        </a>

                        <a asp-area="Admin" asp-controller="Home" asp-action="Delete" asp-route-id="@m.Id" class="btn btn-danger">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>