<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>@ViewData["Title"] - Cinema System</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            body {
                background-color: #0f172a;
                color: white;
            }

            .navbar {
                background-color: #020617;
            }

            .navbar-brand {
                font-weight: bold;
                color: #38bdf8 !important;
            }

            .nav-link {
                color: #cbd5f5 !important;
            }

                .nav-link:hover {
                    color: white !important;
                }

            footer {
                background-color: #020617;
                padding: 15px;
                text-align: center;
                margin-top: 50px;
                color: #94a3b8;
            }
    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="/">🎬 Cinema</a>

            <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <ul class="navbar-nav ms-auto">

                <li class="nav-item">
                    <a class="nav-link"
                       asp-area="Customer"
                       asp-controller="Home"
                       asp-action="Index">Movies</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link"
                       asp-area="Customer"
                       asp-controller="Home"
                       asp-action="Categories">Categories</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link"
                       asp-area="Customer"
                       asp-controller="Home"
                       asp-action="Transactions">Transactions</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link"
                       asp-area="Admin"
                       asp-controller="Admin"
                       asp-action="Index">Admin</a>
                </li>

            </ul>
        </div>

    </nav>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success text-center">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger text-center">
            @TempData["Error"]
        </div>
    }

    <!--  Content -->
    <div class="container py-5">
        @RenderBody()
    </div>

    <!--  Footer -->
    <footer>
        <p>© 2026 Cinema System - Made by Yousef 💪</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>